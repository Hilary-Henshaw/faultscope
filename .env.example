# ─────────────────────────────────────────────────────────────
# FaultScope Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Kafka ─────────────────────────────────────────────────────
FAULTSCOPE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FAULTSCOPE_KAFKA_CONSUMER_GROUP=faultscope-main
FAULTSCOPE_KAFKA_TOPIC_SENSOR_READINGS=faultscope.sensors.readings
FAULTSCOPE_KAFKA_TOPIC_COMPUTED_FEATURES=faultscope.features.computed
FAULTSCOPE_KAFKA_TOPIC_RUL_PREDICTIONS=faultscope.predictions.rul
FAULTSCOPE_KAFKA_TOPIC_INCIDENTS=faultscope.incidents.triggered

# ── TimescaleDB ───────────────────────────────────────────────
FAULTSCOPE_DB_HOST=localhost
FAULTSCOPE_DB_PORT=5432
FAULTSCOPE_DB_NAME=faultscope
FAULTSCOPE_DB_USER=faultscope
FAULTSCOPE_DB_PASSWORD=changeme_in_production
FAULTSCOPE_DB_POOL_SIZE=10
FAULTSCOPE_DB_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────
FAULTSCOPE_REDIS_URL=redis://localhost:6379/0

# ── MinIO / Object Storage ───────────────────────────────────
FAULTSCOPE_MINIO_ENDPOINT=localhost:9000
FAULTSCOPE_MINIO_ACCESS_KEY=minioadmin
FAULTSCOPE_MINIO_SECRET_KEY=changeme_in_production
FAULTSCOPE_MINIO_BUCKET=faultscope-models
FAULTSCOPE_MINIO_SECURE=false

# ── MLflow ────────────────────────────────────────────────────
FAULTSCOPE_MLFLOW_TRACKING_URI=http://localhost:5000
FAULTSCOPE_MLFLOW_EXPERIMENT_NAME=faultscope-production
FAULTSCOPE_MLFLOW_ARTIFACT_ROOT=s3://faultscope-models

# ── Inference Service ─────────────────────────────────────────
FAULTSCOPE_INFERENCE_HOST=0.0.0.0
FAULTSCOPE_INFERENCE_PORT=8000
FAULTSCOPE_INFERENCE_WORKERS=4
FAULTSCOPE_INFERENCE_API_KEY=replace-with-secure-random-key
FAULTSCOPE_INFERENCE_MODEL_RELOAD_INTERVAL_S=60
FAULTSCOPE_INFERENCE_RATE_LIMIT_PER_MINUTE=100

# ── Alert Service ─────────────────────────────────────────────
FAULTSCOPE_ALERTING_HOST=0.0.0.0
FAULTSCOPE_ALERTING_PORT=8001
FAULTSCOPE_ALERTING_AGGREGATION_WINDOW_S=300

# ── Email Notifications ───────────────────────────────────────
FAULTSCOPE_EMAIL_SMTP_HOST=smtp.example.com
FAULTSCOPE_EMAIL_SMTP_PORT=587
FAULTSCOPE_EMAIL_USERNAME=alerts@example.com
FAULTSCOPE_EMAIL_PASSWORD=changeme
FAULTSCOPE_EMAIL_FROM=FaultScope Alerts <alerts@example.com>
FAULTSCOPE_EMAIL_RECIPIENTS=ops-team@example.com,on-call@example.com

# ── Slack Notifications ───────────────────────────────────────
FAULTSCOPE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
FAULTSCOPE_SLACK_CHANNEL=#equipment-alerts
FAULTSCOPE_SLACK_MENTION_HANDLE=@on-call

# ── OpenTelemetry ─────────────────────────────────────────────
FAULTSCOPE_OTEL_ENABLED=false
FAULTSCOPE_OTEL_EXPORTER_ENDPOINT=http://localhost:4317
FAULTSCOPE_OTEL_SERVICE_NAME=faultscope

# ── Logging ───────────────────────────────────────────────────
FAULTSCOPE_LOG_LEVEL=INFO
FAULTSCOPE_LOG_FORMAT=json

# ── Feature Engineering ───────────────────────────────────────
FAULTSCOPE_STREAM_ROLLING_WINDOWS_S=10,30,60,300
FAULTSCOPE_STREAM_FFT_SAMPLING_RATE_HZ=100
FAULTSCOPE_STREAM_BATCH_SIZE=100
FAULTSCOPE_STREAM_FLUSH_INTERVAL_S=5

# ── Training ──────────────────────────────────────────────────
FAULTSCOPE_TRAINING_SEQUENCE_LENGTH=50
FAULTSCOPE_TRAINING_BATCH_SIZE=32
FAULTSCOPE_TRAINING_MAX_EPOCHS=100
FAULTSCOPE_TRAINING_EARLY_STOP_PATIENCE=20

# ── Dashboard ─────────────────────────────────────────────────
FAULTSCOPE_DASHBOARD_REFRESH_INTERVAL_S=5
